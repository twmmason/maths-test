# Copy to .env.local and fill in real values (never commit .env.local)
VITE_GEMINI_API_KEY=your-gemini-api-key
# Optional: comma-separated extra keys, rotated on rate-limit (429) errors
VITE_GEMINI_API_KEY_POOL=key-1,key-2,key-3
# Optional: Google Photorealistic 3D Tiles terrain for the takram atmosphere scene
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# Launch callout voices use Gemini TTS via VITE_GEMINI_API_KEY (cached in
# IndexedDB; falls back to browser speechSynthesis, then captions).
